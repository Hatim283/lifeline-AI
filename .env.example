# Google Generative AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# External APIs
# Note: Ensure the following APIs are enabled for this Google Maps API key:
# - Directions API
# - Geocoding API
# - Geolocation API
# - Places API (New)
# - Places API
# - Time Zone API
# - Routes API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Note: Ensure the Weather API is enabled for this key.
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret_here
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8501/oauth2callback

# Application
LOG_LEVEL=INFO
APP_ENV=development